# TrendHive Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Agentic AI LLM Configuration ─────────────────────────────────────
# Choose provider: "openai" or "anthropic"
LLM_PROVIDER=openai

# OpenAI (if using OpenAI as LLM provider)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini

# Anthropic (if using Anthropic as LLM provider)
ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ── Email Agent ──────────────────────────────────────────────────────
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_RECEIVER=default-receiver@example.com

# ── Internal API URL (Agentic AI → Main API) ────────────────────────
TRENDHIVE_API=http://localhost:8000
