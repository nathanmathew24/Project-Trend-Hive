# TrendHive Frontend — Environment Variables
# Copy this file to .env.local and adjust if needed

# Main Cafe API (FastAPI backend)
VITE_API_URL=http://localhost:8000

# Agentic AI API (for AI Copilot chatbot)
VITE_AGENT_API=http://localhost:8001

# Email API (optional, for login/welcome emails)
VITE_EMAIL_API=http://localhost:8003
